#!/usr/bin/env bash
set -euo pipefail

# Query and identity defaults. Empty repo/user values are resolved from gh.
REPO=""
GH_USER=""
LABEL="${PRCHECK_DEFAULT_LABEL:-}"
NO_LABEL=false
LIMIT=50
AUTHORS="${PRCHECK_AUTHORS:-}"  # comma-separated GitHub logins

# Output and action flags.
TITLE_AS_HYPERLINK=true
JSON_OUTPUT=false
REQUEST_REVIEW=false
STACK_MODE=false

# Only show PRs with no meaningful approvals (bots/apps and PR-author reviews
# are ignored the same way the Status column ignores them).
NO_APPROVALS=false
# Default: exclude PRs where base branch is not the repo's default branch
EXCLUDE_NON_DEFAULT_BASE=true
# Default: only union in PRs that directly request the user as a reviewer.
# Team review requests (e.g. a large "Engineering" group) are excluded so the
# list stays focused on PRs explicitly aimed at the user. Use
# --include-team-review-requests to also include team-based requests.
INCLUDE_TEAM_REVIEW_REQUESTS=false
# Only consider PRs opened within this many days (empty = no date filter).
CREATED_WITHIN_DAYS=""

# Show Greptile's latest reported confidence score as an extra table column.
# Set PRCHECK_GREPTILE_CONFIDENCE=true to make this persistent.
case "${PRCHECK_GREPTILE_CONFIDENCE:-false}" in
  true|TRUE|1|yes|YES) SHOW_GREPTILE_CONFIDENCE=true ;;
  *) SHOW_GREPTILE_CONFIDENCE=false ;;
esac
# Track whether identity values came from the CLI rather than auto-detection.
USER_SET=false
REPO_SET=false

print_help() {
  cat <<EOF
Usage: $0 [options]

Options:
  -r, --repo OWNER/REPO           Repository (default: ${REPO:-auto})
  -l, --label LABEL               Filter by label (default: \$PRCHECK_DEFAULT_LABEL; none if unset)
  -L, --no-label                  Do not filter by label
  -a, --authors USER1,USER2       Comma-separated authors (GitHub logins) to include
      --no-approvals              Only show PRs without any approvals
  -u, --user USERNAME             Your GitHub username (default: ${GH_USER:-auto})
  -n, --limit N                   Max PRs to fetch (default: ${LIMIT})
      --created-within DAYS       Only PRs opened within the last DAYS days (e.g. 14 for two weeks)
      --request-review            Request a review from your user on each listed PR
                                  (skips PRs where you're already a requested reviewer)
      --include-all-base-branches Include PRs targeting any base branch (default: only default branch)
      --include-team-review-requests
                                  Also include PRs where review is requested via a team you belong to
                                  (default: only direct/individual review requests)
      --title-as-hyperlink        Title embeds URL (default)
      --no-title-as-hyperlink     Show URL as separate column
      --greptile-confidence       Show Greptile's latest confidence score
      --stack-mode                Group stacked PRs, including non-default base branches
  -j, --json                      Output JSON instead of table
      --update                    Update prcheck to the latest version from GitHub
      --completion zsh            Print zsh completion script
      --install-zsh-completion    Install zsh completion to ~/.local/share/zsh/site-functions
      --uninstall-zsh-completion  Remove installed zsh completion and managed ~/.zshrc block
  -h, --help                      Show this help

Examples:
  $0
  $0 -r myorg/myrepo -l "Platform" -u myuser -n 100
  $0 -L
  $0 --no-title-as-hyperlink
  $0 -a user1,user2
  $0 --no-approvals
  $0 --greptile-confidence
  $0 --created-within 14
  $0 --created-within 14 --request-review
  $0 --include-all-base-branches
  $0 --stack-mode

Requires: gh (authenticated with repo scope), jq.
EOF
}

# Self-update: fetch the latest bin/prcheck from GitHub main and replace this
# script in-place. There is no version metadata in the repo, so "latest" means
# whatever is currently on main. cmp -s short-circuits when the local file
# already matches, so re-running is a no-op.
self_update() {
  local remote_url="https://raw.githubusercontent.com/connorlanewhite/prcheck/main/bin/prcheck"

  command -v curl >/dev/null 2>&1 || {
    echo "[prcheck] Error: curl is required for --update" >&2
    exit 1
  }

  # Resolve the actual path of the running script. $0 may be a bare name
  # ("prcheck") when invoked from PATH; command -v expands it.
  local script_path
  script_path=$(command -v -- "$0" 2>/dev/null || echo "$0")
  case "$script_path" in
    /*) ;;
    *)  script_path="$(pwd)/$script_path" ;;
  esac

  if [ ! -f "$script_path" ]; then
    echo "[prcheck] Error: could not locate the running script (looked at $script_path)" >&2
    exit 1
  fi

  local install_dir
  install_dir=$(dirname "$script_path")
  if [ ! -w "$install_dir" ]; then
    echo "[prcheck] Error: $install_dir is not writable. Re-run with sudo or reinstall via install.sh." >&2
    exit 1
  fi

  # Stage the download alongside the destination so the final mv stays on the
  # same filesystem (and is therefore atomic).
  local tmpfile
  tmpfile=$(mktemp "${install_dir}/prcheck.XXXXXX") || {
    echo "[prcheck] Error: could not create temp file in $install_dir" >&2
    exit 1
  }
  trap 'rm -f "$tmpfile"' EXIT

  if ! curl -fsSL "$remote_url" -o "$tmpfile"; then
    echo "[prcheck] Error: failed to download $remote_url" >&2
    exit 1
  fi

  if cmp -s "$script_path" "$tmpfile"; then
    echo "You're running the latest version."
    exit 0
  fi

  chmod +x "$tmpfile"
  mv "$tmpfile" "$script_path"
  trap - EXIT
  echo "Updated prcheck to the latest version."
  exit 0
}

print_zsh_completion() {
  cat <<'EOF'
#compdef prcheck

_prcheck() {
  _arguments -s -S \
    '(-r --repo)'{-r,--repo}'[Repository]:repository (OWNER/REPO):' \
    '(-l --label)'{-l,--label}'[Filter by label]:label:' \
    '(-L --no-label)'{-L,--no-label}'[Do not filter by label]' \
    '(-a --authors)'{-a,--authors}'[Comma-separated authors to include]:authors:' \
    '--no-approvals[Only show PRs without any approvals]' \
    '(-u --user)'{-u,--user}'[GitHub username]:username:' \
    '(-n --limit)'{-n,--limit}'[Max PRs to fetch]:limit:' \
    '--created-within[Only PRs opened within the last N days]:days:' \
    '--request-review[Request a review from your user on each listed PR]' \
    '--include-all-base-branches[Include PRs targeting any base branch]' \
    '--include-team-review-requests[Include team-based review requests]' \
    '--title-as-hyperlink[Embed URL in title]' \
    '--no-title-as-hyperlink[Show URL as a separate column]' \
    '--greptile-confidence[Show Greptile confidence score]' \
    '--stack-mode[Group stacked PRs, including non-default base branches]' \
    '(-j --json)'{-j,--json}'[Output JSON instead of table]' \
    '--update[Update prcheck to the latest version from GitHub]' \
    '--completion[Print shell completion script]:shell:(zsh)' \
    '--install-zsh-completion[Install zsh completion]' \
    '--uninstall-zsh-completion[Uninstall zsh completion]' \
    '(-h --help)'{-h,--help}'[Show help]'
}

_prcheck "$@"
EOF
}

zsh_quote() {
  local value=$1
  if [[ "$value" == *$'\n'* || "$value" == *$'\r'* ]]; then
    echo "[prcheck] Error: zsh completion paths cannot contain newlines." >&2
    exit 1
  fi
  value=${value//\'/\'\\\'\'}
  printf "'%s'" "$value"
}

validate_zsh_completion_dir() {
  local value=$1
  if [[ "$value" == *$'\n'* || "$value" == *$'\r'* ]]; then
    echo "[prcheck] Error: zsh completion paths cannot contain newlines." >&2
    return 1
  fi
  case "$value" in
    *'$('*|*'`'*)
      echo "[prcheck] Error: zsh completion path contains shell command-substitution syntax." >&2
      echo "[prcheck]        Choose a plain directory path and retry." >&2
      return 1
      ;;
  esac
}

zsh_completion_rc_block() {
  local completion_dir=$1
  local begin_marker=$2
  local end_marker=$3
  local quoted_completion_dir

  quoted_completion_dir=$(zsh_quote "$completion_dir")
  cat <<EOF
$begin_marker
_prcheck_completion_dir=$quoted_completion_dir
if [[ -d "\${_prcheck_completion_dir}" ]]; then
  if (( \${fpath[(Ie)\${_prcheck_completion_dir}]} == 0 )); then
    fpath=("\${_prcheck_completion_dir}" \$fpath)
  fi
  autoload -Uz compinit
  if ! whence compdef >/dev/null 2>&1; then
    compinit
  fi
  if whence compdef >/dev/null 2>&1; then
    autoload -Uz _prcheck
    compdef _prcheck prcheck
  fi
fi
unset _prcheck_completion_dir
$end_marker
EOF
}

marker_count() {
  local marker=$1
  local file=$2
  grep -Fxc "$marker" "$file" 2>/dev/null || true
}

write_zsh_completion_rc_block() {
  local zshrc=$1
  local completion_dir=$2
  local begin_marker=$3
  local end_marker=$4
  local begin_count
  local end_count

  touch "$zshrc"
  begin_count=$(marker_count "$begin_marker" "$zshrc")
  end_count=$(marker_count "$end_marker" "$zshrc")

  if [ "$begin_count" -eq 0 ] && [ "$end_count" -eq 0 ]; then
    {
      echo ""
      zsh_completion_rc_block "$completion_dir" "$begin_marker" "$end_marker"
    } >> "$zshrc"
    return 0
  fi

  if [ "$begin_count" -ne 1 ] || [ "$end_count" -ne 1 ]; then
    echo "[prcheck] Error: found a malformed prcheck completion block in $zshrc." >&2
    echo "[prcheck]        Refusing to edit it automatically. Remove or repair the block and retry." >&2
    return 1
  fi

  local block_file
  local tmpfile
  block_file=$(mktemp "${TMPDIR:-/tmp}/prcheck.zshrc-block.XXXXXX") || {
    echo "[prcheck] Error: could not create temp file for zsh completion block" >&2
    return 1
  }
  tmpfile=$(mktemp "${TMPDIR:-/tmp}/prcheck.zshrc.XXXXXX") || {
    rm -f "$block_file"
    echo "[prcheck] Error: could not create temp file for $zshrc" >&2
    return 1
  }

  zsh_completion_rc_block "$completion_dir" "$begin_marker" "$end_marker" > "$block_file"
  if awk -v begin="$begin_marker" -v end="$end_marker" -v block="$block_file" '
      $0 == begin {
        if (seen_begin) { bad = 1; exit }
        seen_begin = 1
        skip = 1
        while ((getline line < block) > 0) print line
        close(block)
        next
      }
      $0 == end {
        if (!skip) { bad = 1; exit }
        skip = 0
        next
      }
      !skip { print }
      END {
        if (!seen_begin || skip || bad) exit 1
      }
    ' "$zshrc" > "$tmpfile"; then
    cat "$tmpfile" > "$zshrc"
    rm -f "$block_file" "$tmpfile"
    return 0
  fi

  rm -f "$block_file" "$tmpfile"
  echo "[prcheck] Error: found a malformed prcheck completion block in $zshrc." >&2
  echo "[prcheck]        Refusing to edit it automatically. Remove or repair the block and retry." >&2
  return 1
}

remove_zsh_completion_rc_block() {
  local zshrc=$1
  local begin_marker=$2
  local end_marker=$3
  local begin_count
  local end_count

  if [ ! -f "$zshrc" ]; then
    return 0
  fi

  begin_count=$(marker_count "$begin_marker" "$zshrc")
  end_count=$(marker_count "$end_marker" "$zshrc")

  if [ "$begin_count" -eq 0 ] && [ "$end_count" -eq 0 ]; then
    return 0
  fi

  if [ "$begin_count" -ne 1 ] || [ "$end_count" -ne 1 ]; then
    echo "[prcheck] Error: found a malformed prcheck completion block in $zshrc." >&2
    echo "[prcheck]        Refusing to edit it automatically. Remove or repair the block and retry." >&2
    return 1
  fi

  local tmpfile
  tmpfile=$(mktemp "${TMPDIR:-/tmp}/prcheck.zshrc.XXXXXX") || {
    echo "[prcheck] Error: could not create temp file for $zshrc" >&2
    return 1
  }

  if awk -v begin="$begin_marker" -v end="$end_marker" '
      $0 == begin {
        if (seen_begin) { bad = 1; exit }
        seen_begin = 1
        skip = 1
        next
      }
      $0 == end {
        if (!skip) { bad = 1; exit }
        skip = 0
        next
      }
      !skip { print }
      END {
        if (!seen_begin || skip || bad) exit 1
      }
    ' "$zshrc" > "$tmpfile"; then
    cat "$tmpfile" > "$zshrc"
    rm -f "$tmpfile"
    return 0
  fi

  rm -f "$tmpfile"
  echo "[prcheck] Error: found a malformed prcheck completion block in $zshrc." >&2
  echo "[prcheck]        Refusing to edit it automatically. Remove or repair the block and retry." >&2
  return 1
}

install_zsh_completion() {
  local completion_dir="${PRCHECK_ZSH_COMPLETION_DIR:-${HOME}/.local/share/zsh/site-functions}"
  local completion_file="${completion_dir}/_prcheck"
  local zshrc="${PRCHECK_ZSHRC:-${HOME}/.zshrc}"
  local begin_marker="# >>> prcheck zsh completion >>>"
  local end_marker="# <<< prcheck zsh completion <<<"

  validate_zsh_completion_dir "$completion_dir"

  mkdir -p "$completion_dir"
  print_zsh_completion > "$completion_file"

  write_zsh_completion_rc_block "$zshrc" "$completion_dir" "$begin_marker" "$end_marker"
  echo "Installed zsh completion to $completion_file"
  echo "Updated $zshrc"
  echo "Open a new zsh session or run: source $zshrc"
}

uninstall_zsh_completion() {
  local completion_dir="${PRCHECK_ZSH_COMPLETION_DIR:-${HOME}/.local/share/zsh/site-functions}"
  local completion_file="${completion_dir}/_prcheck"
  local zshrc="${PRCHECK_ZSHRC:-${HOME}/.zshrc}"
  local begin_marker="# >>> prcheck zsh completion >>>"
  local end_marker="# <<< prcheck zsh completion <<<"

  rm -f "$completion_file"

  if [ -f "$zshrc" ] && {
    [ "$(marker_count "$begin_marker" "$zshrc")" -gt 0 ] || [ "$(marker_count "$end_marker" "$zshrc")" -gt 0 ]
  }; then
    remove_zsh_completion_rc_block "$zshrc" "$begin_marker" "$end_marker"
    echo "Removed zsh completion from $completion_file"
    echo "Removed prcheck completion block from $zshrc"
  else
    echo "Removed zsh completion from $completion_file"
    echo "No prcheck completion block found in $zshrc"
  fi
}

# --- Parse args ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    -r|--repo) REPO="$2"; REPO_SET=true; shift 2;;
    -l|--label) LABEL="$2"; NO_LABEL=false; shift 2;;
    -L|--no-label) NO_LABEL=true; shift;;
    -a|--authors) AUTHORS="$2"; shift 2;;
    --no-approvals) NO_APPROVALS=true; shift;;
    -u|--user) GH_USER="$2"; USER_SET=true; shift 2;;
    -n|--limit) LIMIT="$2"; shift 2;;
    --created-within) CREATED_WITHIN_DAYS="$2"; shift 2;;
    --request-review) REQUEST_REVIEW=true; shift;;
    # review-requested PRs are now unioned in by default; flag kept as a
    # silent no-op so old invocations still parse.
    --include-review-requested) shift;;
    --include-all-base-branches) EXCLUDE_NON_DEFAULT_BASE=false; shift;;
    --include-team-review-requests) INCLUDE_TEAM_REVIEW_REQUESTS=true; shift;;
    --title-as-hyperlink) TITLE_AS_HYPERLINK=true; shift;;
    --no-title-as-hyperlink) TITLE_AS_HYPERLINK=false; shift;;
    --greptile-confidence) SHOW_GREPTILE_CONFIDENCE=true; shift;;
    --stack-mode) STACK_MODE=true; EXCLUDE_NON_DEFAULT_BASE=false; shift;;
    -j|--json) JSON_OUTPUT=true; shift;;
    --update) self_update;;
    --completion)
      case "${2:-}" in
        zsh) print_zsh_completion; exit 0;;
        "") echo "[prcheck] Error: --completion requires a shell name (supported: zsh)" >&2; exit 1;;
        *) echo "[prcheck] Error: unsupported completion shell: $2 (supported: zsh)" >&2; exit 1;;
      esac
      ;;
    --completion=zsh) print_zsh_completion; exit 0;;
    --completion=*) echo "[prcheck] Error: unsupported completion shell: ${1#*=} (supported: zsh)" >&2; exit 1;;
    --install-zsh-completion) install_zsh_completion; exit 0;;
    --uninstall-zsh-completion) uninstall_zsh_completion; exit 0;;
    -h|--help) print_help; exit 0;;
    *) echo "[prcheck] Error: Unknown option: $1" >&2; print_help; exit 1;;
  esac
done

# --- Checks ---
command -v gh >/dev/null 2>&1 || { echo "[prcheck] Error: gh (GitHub CLI) is not installed. (brew install gh)" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || { echo "[prcheck] Error: jq is not installed. (brew install jq)" >&2; exit 1; }
# jtab is no longer required: table output is rendered in-script so that
# ANSI hyperlink escape codes don't confuse column-width math.

# --- Resolve defaults (user, repo, label from env already handled) ---
# Create a small cache for metadata (gh auth status, gh user).
META_CACHE_DIR="/tmp/prcheck_cache"
mkdir -p "$META_CACHE_DIR"

# Cache `gh auth status` output to skip the ~600ms subprocess on warm runs.
# Only cache on success with a valid 'repo' scope so broken auth states cause
# a real retry on the next invocation.
GH_AUTH_CACHE_FILE="$META_CACHE_DIR/gh_auth_status.txt"
GH_AUTH_TTL="${PRCHECK_AUTH_TTL:-21600}"  # 6 hours
GH_AUTH_OUTPUT=""
GH_AUTH_FROM_CACHE=false

if [ -f "$GH_AUTH_CACHE_FILE" ]; then
  if stat -f %m "$GH_AUTH_CACHE_FILE" >/dev/null 2>&1; then
    GH_AUTH_MTIME=$(stat -f %m "$GH_AUTH_CACHE_FILE")
  else
    GH_AUTH_MTIME=$(stat -c %Y "$GH_AUTH_CACHE_FILE")
  fi
  GH_AUTH_AGE=$(( $(date +%s) - GH_AUTH_MTIME ))
  if [ "$GH_AUTH_AGE" -lt "$GH_AUTH_TTL" ]; then
    GH_AUTH_OUTPUT=$(cat "$GH_AUTH_CACHE_FILE" 2>/dev/null || true)
    [ -n "$GH_AUTH_OUTPUT" ] && GH_AUTH_FROM_CACHE=true
  fi
fi

if [ "$GH_AUTH_FROM_CACHE" = false ]; then
  if ! GH_AUTH_OUTPUT=$(gh auth status 2>&1); then
    echo "[prcheck] Error: gh is not authenticated. Run: gh auth login" >&2
    exit 1
  fi
fi

# Check that gh has the required 'repo' scope
GH_SCOPES=$(echo "$GH_AUTH_OUTPUT" | grep -i "Token scopes:" | head -1 | sed "s/.*Token scopes: //; s/'//g")
if [[ ! "$GH_SCOPES" =~ repo ]]; then
  echo "[prcheck] Error: gh token is missing the required 'repo' scope." >&2
  echo "[prcheck]        Current scopes: $GH_SCOPES" >&2
  echo "[prcheck]        This script requires the 'repo' scope to access:" >&2
  echo "[prcheck]          - PR information and reviews" >&2
  echo "[prcheck]          - File viewer state (which files you've viewed)" >&2
  echo "[prcheck]        To refresh with correct scopes, run: gh auth refresh -s repo" >&2
  # Invalidate any stale cache so the next run re-checks.
  rm -f "$GH_AUTH_CACHE_FILE" 2>/dev/null || true
  exit 1
fi

# Persist a verified-good auth status so future runs can skip the gh call.
if [ "$GH_AUTH_FROM_CACHE" = false ]; then
  echo "$GH_AUTH_OUTPUT" > "$GH_AUTH_CACHE_FILE" 2>/dev/null || true
fi

# Extracted helpers to reduce nested conditionals
resolve_gh_user() {
  # Early return if user explicitly provided or already resolved
  if [ "$USER_SET" = true ] || [ -n "${GH_USER}" ]; then
    return 0
  fi

  local cache_file="$META_CACHE_DIR/gh_user_login.txt"
  local ttl=86400  # 24 hours
  local use_cache=false

  if [ -f "$cache_file" ]; then
    local mtime
    if stat -f %m "$cache_file" >/dev/null 2>&1; then
      mtime=$(stat -f %m "$cache_file")
    else
      mtime=$(stat -c %Y "$cache_file")
    fi
    local now
    now=$(date +%s)
    local age=$(( now - mtime ))
    if [ "$age" -lt "$ttl" ]; then
      use_cache=true
    fi
  fi

  if [ "$use_cache" = true ]; then
    GH_USER=$(cat "$cache_file" 2>/dev/null || true)
    if [ -n "${GH_USER}" ]; then
      return 0
    fi
  fi

  # Try gh api first
  if [ -z "${GH_USER}" ]; then
    GH_USER=$(gh api user -q .login 2>/dev/null || true)
  fi

  # Fallback: parse from the already-captured gh auth status output
  if [ -z "${GH_USER}" ]; then
    GH_USER=$(echo "${GH_AUTH_OUTPUT:-}" | sed -n 's/.*Logged in to .* as \([^ ]*\).*/\1/p' | head -1 || true)
  fi

  if [ -n "${GH_USER}" ]; then
    echo "$GH_USER" > "$cache_file" || true
    return 0
  fi

  echo "[prcheck] Error: Could not determine GitHub username. Pass with -u USER or ensure gh auth is set up." >&2
  exit 1
}

resolve_repo() {
  # Early return if repo explicitly provided or already resolved
  if [ "$REPO_SET" = true ] || [ -n "${REPO}" ]; then
    return 0
  fi

  # Try gh repo view (works within a git repo with remote)
  REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null || true)
  if [ -n "${REPO}" ]; then
    return 0
  fi

  # Fallback to git remote parsing
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    ORIGIN_URL=$(git config --get remote.origin.url 2>/dev/null || true)
    if [[ "$ORIGIN_URL" =~ ^git@github.com:([^/]+)/([^/.]+)(\.git)?$ ]]; then
      REPO="${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
      return 0
    elif [[ "$ORIGIN_URL" =~ ^https?://github.com/([^/]+)/([^/.]+)(\.git)?$ ]]; then
      REPO="${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
      return 0
    fi
  fi

  echo "[prcheck] Error: Could not determine repository. Run this script from within a GitHub repo or pass -r OWNER/REPO." >&2
  exit 1
}

# Resolve GitHub username from gh auth, unless provided via -u/--user
resolve_gh_user

# Resolve repository (OWNER/REPO) from current directory when not provided
resolve_repo

# If no label provided via env or flag, do not filter by label
if [ -z "${LABEL}" ]; then
  NO_LABEL=true
fi

# --- Build search query strings ---
# Primary query: the usual open-PR filter, optionally narrowed by label.
# Secondary query: always fetch PRs where the user is explicitly review-
# requested, regardless of label. The two result sets are unioned in jq so
# that review-requested PRs outside your team's label still surface.
#
# By default we use `user-review-requested:` so that team-based requests
# (e.g. a large "Engineering" group) don't drag in PRs that aren't really
# pointed at the user. `--include-team-review-requests` switches to the
# broader `review-requested:` qualifier which includes team membership.
SEARCH_Q_BASE="repo:${REPO} is:pr is:open"

# Narrow all three searches to PRs opened within the last N days, if requested.
if [ -n "$CREATED_WITHIN_DAYS" ]; then
  case "$CREATED_WITHIN_DAYS" in
    ''|*[!0-9]*) echo "[prcheck] Error: --created-within expects a positive integer (days)." >&2; exit 1;;
  esac
  # BSD (macOS) and GNU date take different relative-date flags.
  if SINCE_DATE=$(date -v-"${CREATED_WITHIN_DAYS}"d +%Y-%m-%d 2>/dev/null); then
    :
  else
    SINCE_DATE=$(date -d "${CREATED_WITHIN_DAYS} days ago" +%Y-%m-%d)
  fi
  SEARCH_Q_BASE="${SEARCH_Q_BASE} created:>=${SINCE_DATE}"
fi

# Drafts only surface via the review-requested query below, never the label one.
SEARCH_Q="${SEARCH_Q_BASE} -is:draft"
if [ "$NO_LABEL" = false ]; then
  SEARCH_Q="${SEARCH_Q} label:\"${LABEL}\""
fi
SEARCH_Q="${SEARCH_Q} sort:updated-desc"

if [ "$INCLUDE_TEAM_REVIEW_REQUESTS" = true ]; then
  REVIEW_REQUESTED_QUALIFIER="review-requested:${GH_USER}"
else
  REVIEW_REQUESTED_QUALIFIER="user-review-requested:${GH_USER}"
fi

# Omits -is:draft so a draft you're specifically requested on still shows.
SEARCH_Q_REVIEW_REQUESTED="${SEARCH_Q_BASE} ${REVIEW_REQUESTED_QUALIFIER} sort:updated-desc"

# PRs you've already reviewed, regardless of label; the jq filter still drops
# them once you've re-reviewed with no newer commits/files.
SEARCH_Q_REVIEWED_BY="${SEARCH_Q_BASE} -is:draft reviewed-by:${GH_USER} sort:updated-desc"

# Merged ancestors still define a stack's branch lineage. Fetch recent ones
# separately so they can appear as dimmed context without becoming results.
SEARCH_Q_STACK_MEMBERS="repo:${REPO} is:pr is:merged"
if [ "$NO_LABEL" = false ]; then
  SEARCH_Q_STACK_MEMBERS="${SEARCH_Q_STACK_MEMBERS} label:\"${LABEL}\""
elif [ -n "$AUTHORS" ] && [[ "$AUTHORS" != *,* ]]; then
  SEARCH_Q_STACK_MEMBERS="${SEARCH_Q_STACK_MEMBERS} author:${AUTHORS}"
fi
SEARCH_Q_STACK_MEMBERS="${SEARCH_Q_STACK_MEMBERS} sort:updated-desc"

# GitHub App comments require the app/ qualifier in issue search. Mirror each
# candidate search so the Greptile-only result sets cannot add unrelated PRs
# or lose older candidates behind a single broad search result limit.
GREPTILE_COMMENTER="commenter:app/greptile-apps"
SEARCH_Q_GREPTILE_PRIMARY="${SEARCH_Q} ${GREPTILE_COMMENTER}"
SEARCH_Q_GREPTILE_REVIEW_REQUESTED="${SEARCH_Q_REVIEW_REQUESTED} ${GREPTILE_COMMENTER}"
SEARCH_Q_GREPTILE_REVIEWED_BY="${SEARCH_Q_REVIEWED_BY} ${GREPTILE_COMMENTER}"

# --- GraphQL query (single call) ---
GRAPHQL_QUERY=$(cat <<'GRAPHQL'
query(
  $primaryQuery: String!
  $reviewRequestedQuery: String!
  $reviewedByQuery: String!
  $stackMembersQuery: String!
  $greptilePrimaryQuery: String!
  $greptileReviewRequestedQuery: String!
  $greptileReviewedByQuery: String!
  $limit: Int!
  $includeGreptileConfidence: Boolean!
  $includeStackMembers: Boolean!
) {
  primary: search(query: $primaryQuery, type: ISSUE, first: $limit) {
    nodes { ...prFields }
  }
  reviewRequested: search(query: $reviewRequestedQuery, type: ISSUE, first: $limit) {
    nodes { ...prFields }
  }
  reviewedBy: search(query: $reviewedByQuery, type: ISSUE, first: $limit) {
    nodes { ...prFields }
  }
  stackMembers: search(
    query: $stackMembersQuery
    type: ISSUE
    first: 100
  ) @include(if: $includeStackMembers) {
    nodes { ...stackPrFields }
  }
  greptilePrimary: search(
    query: $greptilePrimaryQuery
    type: ISSUE
    first: $limit
  ) @include(if: $includeGreptileConfidence) {
    nodes { ...greptileFields }
  }
  greptileReviewRequested: search(
    query: $greptileReviewRequestedQuery
    type: ISSUE
    first: $limit
  ) @include(if: $includeGreptileConfidence) {
    nodes { ...greptileFields }
  }
  greptileReviewedBy: search(
    query: $greptileReviewedByQuery
    type: ISSUE
    first: $limit
  ) @include(if: $includeGreptileConfidence) {
    nodes { ...greptileFields }
  }
}

fragment prFields on PullRequest {
  number
  state
  title
  url
  updatedAt
  baseRefName
  headRefName
  repository {
    defaultBranchRef { name }
  }
  author { login ... on User { name } }
  commits(last: 10) {
    nodes { commit { committedDate } }
  }
  reviews(last: 50) {
    nodes {
      author { login __typename }
      bodyText @include(if: $includeGreptileConfidence)
      state
      submittedAt
    }
  }
  reviewRequests(first: 50) {
    nodes { requestedReviewer { ... on User { login } } }
  }
  files(first: 100) {
    nodes { viewerViewedState }
    pageInfo { hasNextPage }
  }
}

fragment stackPrFields on PullRequest {
  number
  state
  title
  url
  updatedAt
  baseRefName
  headRefName
  repository {
    defaultBranchRef { name }
  }
  author { login ... on User { name } }
  reviews(last: 50) {
    nodes {
      author { login __typename }
      state
      submittedAt
    }
  }
}

fragment greptileFields on PullRequest {
  number
  # The companion searches already filter to Greptile-commented PRs, so this
  # minimal fragment avoids re-fetching the full candidate data.
  comments(last: 20) {
    nodes {
      author { login }
      bodyText
      createdAt
    }
  }
}
GRAPHQL
)

# --- Fetch and transform ---

# Convert EXCLUDE_NON_DEFAULT_BASE to jq boolean
if [ "$EXCLUDE_NON_DEFAULT_BASE" = true ]; then
  JQ_EXCLUDE_NON_DEFAULT_BASE="true"
else
  JQ_EXCLUDE_NON_DEFAULT_BASE="false"
fi

# Column widths for table output. Title is sized from the terminal, with a
# default floor so PR titles are still useful in narrower panes.
AUTHOR_W=18
TYPE_W=14
STATUS_W=24
UPDATED_W=14
GREPTILE_W=9
STACK_W=6
TABLE_COLUMNS=5
TABLE_FIXED_W=$((AUTHOR_W + TYPE_W + STATUS_W + UPDATED_W))
if [ "$SHOW_GREPTILE_CONFIDENCE" = true ]; then
  TABLE_COLUMNS=6
  TABLE_FIXED_W=$((TABLE_FIXED_W + GREPTILE_W))
fi
if [ "$STACK_MODE" = true ]; then
  TABLE_COLUMNS=$((TABLE_COLUMNS + 1))
  TABLE_FIXED_W=$((TABLE_FIXED_W + STACK_W))
fi
# One separator on each outer edge and between every pair of columns, plus two
# padding spaces per column.
FRAME_OVERHEAD=$((TABLE_COLUMNS + 1 + TABLE_COLUMNS * 2))
TERM_WIDTH=$(tput cols 2>/dev/null || echo 120)
TABLE_MIN_W=140
if [ "$TERM_WIDTH" -lt "$TABLE_MIN_W" ]; then
  TERM_WIDTH=$TABLE_MIN_W
fi
TITLE_W=$((TERM_WIDTH - TABLE_FIXED_W - FRAME_OVERHEAD))
TITLE_MAX_W=100
if [ "$TITLE_W" -gt "$TITLE_MAX_W" ]; then
  TITLE_W=$TITLE_MAX_W
elif [ "$TITLE_W" -lt 36 ]; then
  TITLE_W=36
fi

# Cache (short TTL)
CACHE_DIR="/tmp/prcheck_cache"
CACHE_TTL="${PRCHECK_TTL:-8}"
mkdir -p "$CACHE_DIR"

# Cache key from query parameters. Bump CACHE_VERSION when the GraphQL query
# shape changes so stale caches are not reused.
CACHE_VERSION=v19
CACHE_KEY="${CACHE_VERSION}|${REPO}|${LABEL}|${LIMIT}|${AUTHORS}|${GH_USER}|${NO_APPROVALS}|${EXCLUDE_NON_DEFAULT_BASE}|${INCLUDE_TEAM_REVIEW_REQUESTS}|${CREATED_WITHIN_DAYS}|${SHOW_GREPTILE_CONFIDENCE}|${STACK_MODE}"
CACHE_KEY="${CACHE_KEY//[!a-zA-Z0-9]/_}"
CACHE_FILE="${CACHE_DIR}/${CACHE_KEY}.json"

# Check if cache exists and is fresh (< $CACHE_TTL seconds old)
USE_CACHE=false
if [ -f "$CACHE_FILE" ]; then
  # Get file modification time (macOS uses -f %m, Linux uses -c %Y)
  if stat -f %m "$CACHE_FILE" >/dev/null 2>&1; then
    # macOS
    CACHE_MTIME=$(stat -f %m "$CACHE_FILE")
  else
    # Linux
    CACHE_MTIME=$(stat -c %Y "$CACHE_FILE")
  fi
  CACHE_AGE=$(($(date +%s) - CACHE_MTIME))
  if [ "$CACHE_AGE" -lt "$CACHE_TTL" ]; then
    USE_CACHE=true
  fi
fi

# Fetch data (from cache or API)
if [ "$USE_CACHE" = true ]; then
  GRAPHQL_RESPONSE=$(cat "$CACHE_FILE")
else
  for attempt in 1 2; do
    if GRAPHQL_RESPONSE=$(gh api graphql \
      -F primaryQuery="$SEARCH_Q" \
      -F reviewRequestedQuery="$SEARCH_Q_REVIEW_REQUESTED" \
      -F reviewedByQuery="$SEARCH_Q_REVIEWED_BY" \
      -F stackMembersQuery="$SEARCH_Q_STACK_MEMBERS" \
      -F greptilePrimaryQuery="$SEARCH_Q_GREPTILE_PRIMARY" \
      -F greptileReviewRequestedQuery="$SEARCH_Q_GREPTILE_REVIEW_REQUESTED" \
      -F greptileReviewedByQuery="$SEARCH_Q_GREPTILE_REVIEWED_BY" \
      -F limit="$LIMIT" \
      -F includeGreptileConfidence="$SHOW_GREPTILE_CONFIDENCE" \
      -F includeStackMembers="$STACK_MODE" \
      -f query="$GRAPHQL_QUERY"); then
      break
    fi
    [ "$attempt" -eq 2 ] && exit 1
    echo "[prcheck] GitHub API request failed; retrying..." >&2
    sleep 1
  done
  echo "$GRAPHQL_RESPONSE" > "$CACHE_FILE"
fi

# Shared jq pipeline: selects PRs that need attention and emits the normalized
# fields consumed by JSON output, review requests, and the table renderer.
JQ_PROGRAM='
  def unique_prs:
    map(select(.number != null))
    | group_by(.number)
    | map(.[0]);

  def branch_lineage($branches; $head; $seen):
    if ($seen | index($head)) != null then null
    elif $branches[$head].parent == null then [$head]
    else branch_lineage($branches; $branches[$head].parent; $seen + [$head]) as $parents
      | if $parents == null then null else $parents + [$head] end
    end;

  def stack_marker:
    try (capture("^(?<prefix>.*?)\\(?(?<number>[0-9]{1,2})[\\\\/](?<total>[0-9]{1,2})\\)?([^0-9]|$)")
      | {
          prefix: (.prefix | gsub("\\s+$"; "") | ascii_downcase),
          number: (.number | tonumber),
          total: (.total | tonumber)
        })
    catch null;

  def latest_review_by($login):
    .reviews.nodes
    | map(select(.author.login == $login))
    | if length == 0 then null
      else max_by(.submittedAt // "1970-01-01T00:00:00Z")
      end;

  # Keep one current review state per independent human reviewer. Bot/App
  # activity and replies from the PR author are not independent vetting.
  def latest_independent_reviews:
    . as $pr
    | $pr.reviews.nodes
    | map(select(
        .author != null
        and ((.author.__typename // "") != "Bot")
        and ((.author.login // "") | endswith("[bot]") | not)
        and ((.author.login // "") != ($pr.author.login // ""))
      ))
    | group_by(.author.login)
    | map(max_by(.submittedAt // "1970-01-01T00:00:00Z"));

  # Greptile puts its confidence score in a Markdown heading such as
  # "Confidence Score: 5/5". Treat a changed or malformed format as absent.
  def greptile_confidence_score:
    try ((.bodyText // "")
      | capture("(?i)confidence[[:space:]]+score[[:space:]]*:[[:space:]]*(?<score>[1-5])[[:space:]]*/[[:space:]]*5").score
      | tonumber)
    catch null;

  # Greptile has used both review bodies and timeline comments for summaries.
  # Prefer the newest valid score across both sources.
  def latest_greptile_confidence:
    [
      (.reviews.nodes[]?
        | select((.author.login // "") == "greptile-apps")
        | { confidence: greptile_confidence_score, at: (.submittedAt // "1970-01-01T00:00:00Z") }),
      (.comments.nodes[]?
        | select((.author.login // "") == "greptile-apps")
        | { confidence: greptile_confidence_score, at: (.createdAt // "1970-01-01T00:00:00Z") })
    ]
    | map(select(.confidence != null))
    | if length == 0 then null
      else max_by(.at).confidence
      end;

  # Union the label, review-requested, and reviewed-by result sets, dedupe by
  # PR number, and restore updated-desc ordering. Greptile companion searches
  # only supply comments to those candidates; they never add output rows.
  # Any query may be absent from the response on errors; default to [].
  (
    (
      ((.data.primary.nodes // []) + (.data.reviewRequested.nodes // []) + (.data.reviewedBy.nodes // []) + (.data.stackMembers.nodes // []))
      | unique_prs
    ) as $candidates
    | (
        ((.data.greptilePrimary.nodes // [])
          + (.data.greptileReviewRequested.nodes // [])
          + (.data.greptileReviewedBy.nodes // []))
        | unique_prs
        | INDEX(.number)
      ) as $greptileByNumber
    | $candidates
    | map(
        . as $candidate
        | ($greptileByNumber[($candidate.number | tostring)] // null) as $greptile
        | if $greptile == null then $candidate
          else $candidate + {comments: ($greptile.comments // {nodes: []})}
          end
      )
    | sort_by(.updatedAt)
    | reverse
  )
  | . as $candidates
  | (reduce $candidates[] as $pr
      ({}; .[$pr.headRefName] = true)) as $heads
  | (reduce $candidates[] as $pr
      ({}; .[$pr.baseRefName] = ((.[$pr.baseRefName] // 0) + 1))) as $childCounts
  | (reduce $candidates[] as $pr
      ({}; .[$pr.headRefName] = {
        parent: (if $heads[$pr.baseRefName] then $pr.baseRefName else null end),
        childCount: ($childCounts[$pr.headRefName] // 0)
      })) as $branches
  | ([ $candidates[] as $pr
      | ($pr.title | stack_marker) as $marker
      | select($marker != null)
      | branch_lineage($branches; $pr.headRefName; []) as $lineage
      | {
          root: ($lineage[0] // $pr.headRefName),
          position: ($lineage | length),
          author: ($pr.author.login // "unknown"),
          prefix: $marker.prefix,
          number: $marker.number,
          total: $marker.total
        }
    ]) as $anchors
  | ([$anchors
      | group_by([.author, .prefix, .total])[]
      | select(length > 1)
      | {
          author: .[0].author,
          prefix: .[0].prefix,
          total: .[0].total,
          root: "marker:\(.[0].author):\(.[0].prefix):\(.[0].total)"
        }
    ]) as $explicitStacks
  | (
      if $authorsCsv == "" then []
      else ($authorsCsv
        | split(",")
        | map(gsub("^\\s+|\\s+$"; ""))
        | map(select(. != "")))
      end
    ) as $authors
  | map(
      . as $pr
      | branch_lineage($branches; $pr.headRefName; []) as $stackLineage
      | ($stackLineage[0] // $pr.headRefName) as $stackRoot
      | ($stackLineage | length) as $stackPosition
      | ([$anchors[]
          | select(.root == $stackRoot)
          | . + {distance: ((.position - $stackPosition) | abs)}]
        | sort_by(.distance, .position) | .[0] // null) as $stackAnchor
      | ([$explicitStacks[]
          | select(
              $stackAnchor != null
              and .author == $stackAnchor.author
              and .prefix == $stackAnchor.prefix
              and .total == $stackAnchor.total
            )]
        | .[0] // null) as $explicitStack
      | ($pr | latest_review_by($ghUser)) as $myLastReview
      | (($pr.commits.nodes // []) | map(.commit.committedDate) | any(. > ($myLastReview.submittedAt // "1970-01-01T00:00:00Z"))) as $hasCommitsNewerThanReview
      | (($pr.files.nodes // []) | map(.viewerViewedState) | any(. != "VIEWED")) as $hasUnviewedInFirst100
      | (($pr.files.nodes // []) | map(.viewerViewedState) | any(. == "VIEWED")) as $hasAnyViewed
      | ($pr.files.pageInfo.hasNextPage // false) as $filesHasMore
      | ($myLastReview == null) as $neverReviewed
      | (if $neverReviewed then false else $hasCommitsNewerThanReview end) as $newSinceReview
      | ($hasUnviewedInFirst100 or $filesHasMore) as $unviewedFlag
      | ($neverReviewed or $newSinceReview or $unviewedFlag) as $needsAttention
      | (
          # "Unviewed Files" is reserved for PRs where review has actually
          # started (some files marked viewed, some not). If no review has
          # been submitted and no files are marked viewed, this PR has not
          # been touched at all -- show "Never Reviewed" instead.
          if $newSinceReview then "New Commits"
          elif $neverReviewed and ($hasAnyViewed | not) then "Never Reviewed"
          elif $unviewedFlag then "Unviewed Files"
          elif $neverReviewed then "Never Reviewed"
          else "Reviewed"
          end
        ) as $prType
      | ($pr | latest_independent_reviews) as $latestPerReviewer
      | ($pr | latest_greptile_confidence) as $greptileConfidence
      | ($latestPerReviewer | map(select(.state == "APPROVED"))) as $approvers
      | (($noApprovals == "false") or (($approvers | length) == 0)) as $passesApprovals
      | ($latestPerReviewer | map(select(.state == "CHANGES_REQUESTED"))) as $changeRequesters
      | ($latestPerReviewer | map(select(.state == "COMMENTED" or .state == "DISMISSED"))) as $commenters
      | ($approvers        | map(select(.author.login != $ghUser)) | length) as $approversOthers
      | ($commenters       | map(select(.author.login != $ghUser)) | length) as $commentersOthers
      | ($changeRequesters | map(select(.author.login != $ghUser)) | length) as $changeRequestersOthers
      | ($approvers        | any(.author.login == $ghUser)) as $approvedByYou
      | ($commenters       | any(.author.login == $ghUser)) as $commentedByYou
      | ($changeRequesters | any(.author.login == $ghUser)) as $changesRequestedByYou
      | (
          if $approversOthers > 0 then "Approved by \($approversOthers) Other(s)"
          elif $approvedByYou then "Approved by You"
          elif $commentersOthers > 0 then "Reviewed by \($commentersOthers) Other(s)"
          elif $commentedByYou then "Reviewed by You"
          elif $changeRequestersOthers > 0 then "Changes by \($changeRequestersOthers) Other(s)"
          elif $changesRequestedByYou then "Changes Requested by You"
          else "Unreviewed"
          end
        ) as $reviewStatus
      | (
          # Higher = more "done", safer to skip. Used only to pick a color in
          # the renderer; not surfaced as a user-visible string.
          if $changeRequestersOthers > 0 or $changesRequestedByYou then "changes_requested"
          elif $approvedByYou then "vetted"
          elif $approversOthers >= 2 and $commentersOthers == 0 then "vetted"
          elif $approversOthers >= 1 and ($commentersOthers > 0) then "approved_mixed"
          elif $approversOthers >= 2 then "approved"
          elif $approversOthers == 1 then "approved_pale"
          elif $commentersOthers > 0 or $commentedByYou then "commented"
          else "unreviewed"
          end
        ) as $tone
      | ((.updatedAt | fromdate) | strflocaltime("%-m/%-d %-I:%M %p")) as $updatedLocal
      | (if ($pr.author.name // "" | length) > 0 then $pr.author.name else ($pr.author.login // "unknown") end) as $author
      | ((($pr.author.login // "unknown") != $ghUser)) as $passesSelfAuthor
      | ((($authors | length) == 0) or (($authors | index(($pr.author.login // ""))) != null)) as $passesAuthors
      | (($excludeNonDefaultBase == "false") or ($pr.baseRefName == $pr.repository.defaultBranchRef.name)) as $passesBase
      | (($pr.reviewRequests.nodes // []) | any(.requestedReviewer.login == $ghUser)) as $selfRequested
      | (.title | gsub("[\\n\\r\\t]"; " ") | gsub(" +"; " ")) as $clean_title
      | {
          number: $pr.number,
          title: $clean_title,
          url: .url,
          author: $author,
          _stack: {
            root: ($explicitStack.root // $stackRoot),
            position: (if $explicitStack == null then $stackPosition else $stackAnchor.number end),
            childCount: ($branches[$pr.headRefName].childCount // 0),
            updatedAt: $pr.updatedAt,
            anchoredNumber: (if $stackAnchor == null then null
              else $stackAnchor.number + $stackPosition - $stackAnchor.position end),
            anchoredTotal: ($stackAnchor.total // null)
          },
          type: $prType,
          status: $reviewStatus,
          tone: $tone,
          updated: $updatedLocal,
          greptileConfidence: $greptileConfidence,
          selfRequested: $selfRequested,
          _approvedByYou: $approvedByYou,
          _visible: (($pr.state // "OPEN") == "OPEN" and $needsAttention and $passesApprovals and $passesSelfAuthor and $passesAuthors and $passesBase)
        }
    )
'

# Expand a stack when any member needs attention. Filtered members remain in
# the tree as dimmed children; unrelated stacks stay hidden.
JQ_STACK_PROGRAM=' | (
  def stack_layout:
    group_by(._stack.root) | map(
      . as $group
      | ($group | sort_by(._stack.position, .number) | to_entries
        | map(.value + {_stackPosition: (.key + 1)})) as $rows
      | ($rows | max_by(._stack.updatedAt)) as $latestRow
      | {
          latest: $latestRow._stack.updatedAt,
          latestDisplay: $latestRow.updated,
          rows: $rows,
          size: ($group | length),
          forked: ($group | any(._stack.childCount > 1)),
          approvedByYou: ($group | map(select(._approvedByYou)) | length),
          visible: ($group | any(._visible))
        }
    )
    | map(select(.visible))
    | sort_by(.latest) | reverse
    | .[] as $group
    | if $group.size == 1 then
        $group.rows[] | select(._visible)
        | . + {
            stack: "-",
            tree: "",
            _dimmed: false,
            _parent: false
          }
      else
        ({
          title: "Stack: \($group.rows[0].title)",
          url: "",
          tree: "",
          stack: "\($group.size) PRs",
          author: $group.rows[0].author,
          type: "Stack",
          status: "\($group.approvedByYou)/\($group.size) approved by you",
          updated: $group.latestDisplay,
          tone: "unreviewed",
          greptileConfidence: null,
          _dimmed: false,
          _parent: true
        }),
        ($group.rows | to_entries[]
          | .key as $index | .value
          | . + {
              tree: (if $index == ($group.size - 1) then "└─ " else "├─ " end),
              stack: (if $group.forked then "fork"
                elif ._stack.anchoredNumber != null then "\(._stack.anchoredNumber)/\(._stack.anchoredTotal)"
                else "\(._stackPosition)/\($group.size)" end),
              updated: "",
              _dimmed: (._visible | not),
              _parent: false
            })
      end;
  stack_layout
)'

if [ "$REQUEST_REVIEW" = true ]; then
  # Request a review from GH_USER on each listed PR, skipping any where they're
  # already a requested reviewer. Reuses the same filtered set the table shows.
  REQUEST_TARGETS=$(echo "$GRAPHQL_RESPONSE" | jq -r \
    --arg ghUser "$GH_USER" \
    --arg authorsCsv "$AUTHORS" \
    --arg noApprovals "$NO_APPROVALS" \
    --arg excludeNonDefaultBase "$JQ_EXCLUDE_NON_DEFAULT_BASE" \
    "$JQ_PROGRAM"' | .[] | select(._visible and (.selfRequested | not)) | "\(.number)\t\(.url)"')

  if [ -z "$REQUEST_TARGETS" ]; then
    echo "[prcheck] Nothing to do: you're already a requested reviewer on every listed PR (or none matched)."
    exit 0
  fi

  while IFS=$'\t' read -r num url; do
    [ -z "$num" ] && continue
    if gh api -X POST "repos/${REPO}/pulls/${num}/requested_reviewers" \
         -f "reviewers[]=${GH_USER}" >/dev/null 2>&1; then
      echo "[prcheck] Requested review on #${num}: ${url}"
    else
      echo "[prcheck] Could not request review on #${num} (author, already requested, or no access): ${url}" >&2
    fi
  done <<< "$REQUEST_TARGETS"
  exit 0
fi

if [ "$JSON_OUTPUT" = true ]; then
  echo "$GRAPHQL_RESPONSE" | jq \
    --arg ghUser "$GH_USER" \
    --arg authorsCsv "$AUTHORS" \
    --arg noApprovals "$NO_APPROVALS" \
    --arg excludeNonDefaultBase "$JQ_EXCLUDE_NON_DEFAULT_BASE" \
    "$JQ_PROGRAM"' | map(select(._visible) | del(._stack, ._approvedByYou, ._visible))'
  exit 0
fi

# Table output: emit normalized TSV rows, then render fixed-width cells in Bash
# so ANSI hyperlink and color escape bytes do not distort column widths.
TABLE_JQ_PROGRAM="$JQ_PROGRAM"' | .[] | select(._visible)'
if [ "$STACK_MODE" = true ]; then
  TABLE_JQ_PROGRAM="$JQ_PROGRAM$JQ_STACK_PROGRAM"
else
  TABLE_JQ_PROGRAM="$TABLE_JQ_PROGRAM | . + {stack: \"-\", tree: \"\", _dimmed: false, _parent: false}"
fi

ROW_DATA=$(echo "$GRAPHQL_RESPONSE" | jq -r \
  --arg ghUser "$GH_USER" \
  --arg authorsCsv "$AUTHORS" \
  --arg noApprovals "$NO_APPROVALS" \
  --arg excludeNonDefaultBase "$JQ_EXCLUDE_NON_DEFAULT_BASE" \
  "$TABLE_JQ_PROGRAM"' | [.title, .url, .tree, .stack, .author, .type, .status, .updated, .tone, (if .greptileConfidence == null then "-" else "\(.greptileConfidence)/5" end), ._dimmed, ._parent] | join("\u001f")')

# Truncate a string to a visible width, appending "..." if cut. Writes the
# result into the named variable (printf -v) to avoid a subshell per call.
truncate_to_var() {
  local __var=$1 s=$2 w=$3
  if [ "${#s}" -gt "$w" ]; then
    local keep=$(( w - 3 ))
    [ "$keep" -lt 1 ] && keep=1
    printf -v "$__var" '%s...' "${s:0:$keep}"
  else
    printf -v "$__var" '%s' "$s"
  fi
}

# Repeat a character N times into a named variable (no subshell, no loop).
repeat_to_var() {
  local __var=$1 ch=$2 n=$3 tmp
  printf -v tmp '%*s' "$n" ""
  printf -v "$__var" '%s' "${tmp// /$ch}"
}

ESC=$'\033'
RESET="${ESC}[0m"
DIM="${ESC}[2m"
BOLD="${ESC}[1m"
GREEN="${ESC}[32m"
YELLOW="${ESC}[33m"
RED="${ESC}[31m"

# Pick a color for the Status cell based on the tone emitted by jq. On
# truecolor terminals, use a GitHub-inspired ramp so that the amount of
# independent vetting (and any dissent) is visible at a glance. On lesser
# terminals, fall back to the original 3-color scheme.
if [ "${COLORTERM:-}" = "truecolor" ] || [ "${COLORTERM:-}" = "24bit" ]; then
  TONE_VETTED="${ESC}[38;2;35;197;84m"      # vibrant green
  TONE_APPROVED="${ESC}[38;2;86;211;100m"   # green
  TONE_APPROVED_PALE="${ESC}[38;2;126;231;135m"  # pale green
  TONE_APPROVED_MIXED="${ESC}[38;2;166;183;113m" # olive
  TONE_COMMENTED="${ESC}[38;2;227;179;65m"  # yellow
  TONE_CHANGES="${ESC}[38;2;248;81;73m"     # red
else
  # 8-color fallback: preserve the original scheme exactly (any Approved* is
  # green, Reviewed/commented is yellow, Changes Requested is red). The fine-
  # grained ramp only activates on terminals that can render it.
  TONE_VETTED=$GREEN
  TONE_APPROVED=$GREEN
  TONE_APPROVED_PALE=$GREEN
  TONE_APPROVED_MIXED=$GREEN
  TONE_COMMENTED=$YELLOW
  TONE_CHANGES=$RED
fi

# Assign colors with printf -v so rendering does not spawn a command-
# substitution subshell for every cell in every row.
tone_color_to_var() {
  local output_var=$1
  local tone=$2
  local color=""

  case "$tone" in
    vetted)            color=$TONE_VETTED ;;
    approved)          color=$TONE_APPROVED ;;
    approved_pale)     color=$TONE_APPROVED_PALE ;;
    approved_mixed)    color=$TONE_APPROVED_MIXED ;;
    commented)         color=$TONE_COMMENTED ;;
    changes_requested) color=$TONE_CHANGES ;;
  esac
  printf -v "$output_var" '%s' "$color"
}

# Greptile's 1-5 confidence scale shares the status column's established
# truecolor palette, with an 8-color fallback when truecolor is unavailable.
greptile_confidence_color_to_var() {
  local output_var=$1
  local score=$2
  local color=""

  case "$score" in
    5/5) color=$TONE_VETTED ;;          # vibrant green
    4/5) color=$TONE_APPROVED ;;         # good green
    3/5) color=$TONE_APPROVED_MIXED ;;   # olive
    2/5) color=$TONE_COMMENTED ;;        # yellow
    1/5) color=$TONE_CHANGES ;;          # red
  esac
  printf -v "$output_var" '%s' "$color"
}

repeat_to_var H_TITLE   "─" $((TITLE_W + 2))
repeat_to_var H_AUTHOR  "─" $((AUTHOR_W + 2))
repeat_to_var H_TYPE    "─" $((TYPE_W + 2))
repeat_to_var H_STATUS  "─" $((STATUS_W + 2))
repeat_to_var H_UPDATED "─" $((UPDATED_W + 2))
repeat_to_var H_GREPTILE "─" $((GREPTILE_W + 2))
repeat_to_var H_STACK "─" $((STACK_W + 2))

print_border() {
  local left="$1" mid="$2" right="$3"
  local line="${left}${H_TITLE}"
  [ "$STACK_MODE" = true ] && line="${line}${mid}${H_STACK}"
  line="${line}${mid}${H_AUTHOR}${mid}${H_TYPE}${mid}${H_STATUS}"
  [ "$SHOW_GREPTILE_CONFIDENCE" = true ] && line="${line}${mid}${H_GREPTILE}"
  printf '%s%s%s%s\n' "$line" "$mid" "$H_UPDATED" "$right"
}

print_border "┌" "┬" "┐"
printf '│ %-*s ' "$TITLE_W" "Title"
[ "$STACK_MODE" = true ] && printf '│ %-*s ' "$STACK_W" "Stack"
printf '│ %-*s │ %-*s │ %-*s ' "$AUTHOR_W" "Author" "$TYPE_W" "Type" "$STATUS_W" "Status"
[ "$SHOW_GREPTILE_CONFIDENCE" = true ] && printf '│ %-*s ' "$GREPTILE_W" "Greptile"
printf '│ %-*s │\n' "$UPDATED_W" "Updated"
print_border "├" "┼" "┤"

if [ -n "$ROW_DATA" ]; then
  while IFS=$'\x1f' read -r title url tree stack author prType status updated tone greptileConfidence dimmed parent; do
    [ -z "$title" ] && continue
    tree_width=0
    [ -n "$tree" ] && tree_width=3
    truncate_to_var title_disp "$title" $((TITLE_W - tree_width))
    truncate_to_var author_disp "$author" "$AUTHOR_W"
    truncate_to_var stack_disp "$stack" "$STACK_W"
    truncate_to_var type_disp "$prType" "$TYPE_W"
    truncate_to_var status_disp "$status" "$STATUS_W"
    truncate_to_var updated_disp "$updated" "$UPDATED_W"

    # Build the title cell so its VISIBLE width is exactly TITLE_W, then wrap
    # the visible text with OSC 8 hyperlink escapes (which take zero visible
    # columns in terminals that support them).
    title_pad_len=$((TITLE_W - tree_width - ${#title_disp}))
    printf -v title_pad '%*s' "$title_pad_len" ""
    if [ "$TITLE_AS_HYPERLINK" = true ] && [ -n "$url" ]; then
      title_cell="${ESC}]8;;${url}${ESC}\\${tree}${title_disp}${ESC}]8;;${ESC}\\${title_pad}"
    else
      title_cell="${tree}${title_disp}${title_pad}"
    fi

    # Colorize the status cell based on the tone emitted by jq. ANSI color
    # codes are zero-width in rendering, so pad to STATUS_W first, then wrap
    # with color.
    tone_color_to_var status_color "$tone"
    status_pad_len=$((STATUS_W - ${#status_disp}))
    printf -v status_pad '%*s' "$status_pad_len" ""
    if [ -n "$status_color" ]; then
      status_cell="${status_color}${status_disp}${RESET}${status_pad}"
    else
      status_cell="${status_disp}${status_pad}"
    fi

    if [ "$SHOW_GREPTILE_CONFIDENCE" = true ]; then
      greptile_confidence_color_to_var greptile_color "$greptileConfidence"
      greptile_pad_len=$((GREPTILE_W - ${#greptileConfidence}))
      printf -v greptile_pad '%*s' "$greptile_pad_len" ""
      if [ -n "$greptile_color" ]; then
        greptile_cell="${greptile_color}${greptileConfidence}${RESET}${greptile_pad}"
      else
        greptile_cell="${greptileConfidence}${greptile_pad}"
      fi
    fi

    text_prefix=""
    text_suffix=""
    if [ "$dimmed" = true ]; then
      text_prefix=$DIM
      text_suffix=$RESET
    elif [ "$parent" = true ]; then
      text_prefix=$BOLD
      text_suffix=$RESET
    fi

    # Keep styling outside printf field widths so ANSI bytes never move a
    # separator. %s also avoids reinterpreting backslashes in PR titles.
    printf '│ %s%s%s ' "$text_prefix" "$title_cell" "$text_suffix"
    [ "$STACK_MODE" = true ] && printf '│ %s%-*s%s ' "$text_prefix" "$STACK_W" "$stack_disp" "$text_suffix"
    printf '│ %s%-*s%s │ %s%-*s%s │ %s%s%s ' \
      "$text_prefix" "$AUTHOR_W" "$author_disp" "$text_suffix" \
      "$text_prefix" "$TYPE_W" "$type_disp" "$text_suffix" \
      "$text_prefix" "$status_cell" "$text_suffix"
    [ "$SHOW_GREPTILE_CONFIDENCE" = true ] && printf '│ %s%s%s ' "$text_prefix" "$greptile_cell" "$text_suffix"
    printf '│ %s%-*s%s │\n' "$text_prefix" "$UPDATED_W" "$updated_disp" "$text_suffix"
  done <<< "$ROW_DATA"
fi

print_border "└" "┴" "┘"
